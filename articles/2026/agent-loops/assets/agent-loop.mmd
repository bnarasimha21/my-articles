flowchart TD
    A["📥 REQUEST\nfrom User"] --> B["🔍 UNDERSTAND CONTEXT\nRead files, docs,\nsystem state"]
    B --> C["📋 PLAN\nBreak into tasks\nIdentify tools"]
    C --> D["⚡ EXECUTE\nRun commands\nCall APIs\nUse MCP tools"]
    D --> E["👁️ OBSERVE\nCheck output\nAnalyze logs"]
    E --> F{"✅ SUCCESS?"}
    F -- YES --> G["📤 REPORT COMPLETE\nReturn to user"]
    F -- NO --> H["🔎 ANALYZE FAILURE\nWhat went wrong?"]
    H --> I["🔧 FIX & RETRY\nAdjust approach\nTry alternative"]
    I --> D

    style A fill:#4A90D9,stroke:#2E6BA6,color:#fff
